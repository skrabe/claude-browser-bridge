{
  "manifest_version": 3,
  "name": "Better Claude in Chrome",
  "version": "0.10.2",
  "description": "Let Claude Code drive your real, logged-in browser tabs over the Chrome DevTools Protocol — a fuller, owned take on Claude in Chrome.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "debugger",
    "tabs",
    "tabGroups",
    "scripting",
    "nativeMessaging",
    "storage",
    "alarms",
    "downloads",
    "history"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Better Claude in Chrome"
  },
  "key": ""
}
